// Trello Clone data model
// Default-user auth per assignment: a single seeded user owns every board.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  displayName String
  initials    String
  avatarUrl   String?
  color       String   @default("#0079BF")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  ownedBoards  Board[]        @relation("BoardOwner")
  boardMembers BoardMember[]
  cardMembers  CardMember[]
  comments     Comment[]
  activities   Activity[]
}

model Board {
  id             String   @id @default(cuid())
  title          String
  backgroundType String   @default("color")
  backgroundValue String  @default("#0079BF")
  ownerId        String
  starred        Boolean  @default(false)
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner      User          @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  lists      List[]
  cards      Card[]
  labels     Label[]
  members    BoardMember[]
  activities Activity[]

  @@index([ownerId])
  @@index([archivedAt])
}

model BoardMember {
  id       String   @id @default(cuid())
  boardId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

model List {
  id         String   @id @default(cuid())
  boardId    String
  title      String
  position   Float
  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId, position])
  @@index([boardId, archivedAt])
}

model Card {
  id             String    @id @default(cuid())
  boardId        String
  listId         String
  title          String
  description    String    @default("")
  position       Float
  dueAt          DateTime?
  dueComplete    Boolean   @default(false)
  coverType      String?
  coverValue     String?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  board      Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  list       List         @relation(fields: [listId], references: [id], onDelete: Cascade)
  labels     CardLabel[]
  members    CardMember[]
  checklists Checklist[]
  comments   Comment[]
  activities Activity[]

  @@index([listId, position])
  @@index([boardId, archivedAt])
  @@index([dueAt])
}

model Label {
  id        String   @id @default(cuid())
  boardId   String
  name      String   @default("")
  color     String
  createdAt DateTime @default(now())

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]

  @@index([boardId])
}

model CardLabel {
  cardId  String
  labelId String

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
}

model CardMember {
  cardId String
  userId String

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cardId, userId])
  @@index([userId])
}

model Checklist {
  id        String   @id @default(cuid())
  cardId    String
  title     String
  position  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card  Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items ChecklistItem[]

  @@index([cardId, position])
}

model ChecklistItem {
  id          String   @id @default(cuid())
  checklistId String
  text        String
  done        Boolean  @default(false)
  position    Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId, position])
}

model Comment {
  id        String   @id @default(cuid())
  cardId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([cardId, createdAt])
}

model Activity {
  id        String   @id @default(cuid())
  boardId   String
  cardId    String?
  listId    String?
  actorId   String
  type      String
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  card  Card? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  actor User  @relation(fields: [actorId], references: [id])

  @@index([boardId, createdAt])
  @@index([cardId])
}

// -----------------------------------------------------------------------------
// Templates — reusable board blueprints. Instantiation creates a real Board
// with Lists/Cards/Labels/Checklists copied from the template tree. Templates
// themselves are admin-seeded (no user submission flow in v1).
// -----------------------------------------------------------------------------

enum TemplateCategory {
  business
  design
  education
  marketing
  engineering
  sales
}

model Template {
  id                   String           @id @default(cuid())
  title                String
  description          String
  category             TemplateCategory
  coverImageUrl        String?
  coverGradient        String?
  isFeatured           Boolean          @default(false)
  isMostPopular        Boolean          @default(false)
  useCount             Int              @default(0)
  boardBackgroundType  String           @default("color")
  boardBackgroundValue String           @default("#0079BF")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  lists  TemplateList[]
  labels TemplateLabel[]

  @@index([category])
  @@index([isFeatured])
}

model TemplateList {
  id         String   @id @default(cuid())
  templateId String
  title      String
  position   Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  cards    TemplateCard[]

  @@index([templateId, position])
}

model TemplateCard {
  id          String   @id @default(cuid())
  listId      String
  title       String
  description String   @default("")
  position    Float
  coverType   String?
  coverValue  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  list       TemplateList        @relation(fields: [listId], references: [id], onDelete: Cascade)
  labels     TemplateCardLabel[]
  checklists TemplateChecklist[]

  @@index([listId, position])
}

model TemplateLabel {
  id         String   @id @default(cuid())
  templateId String
  name       String   @default("")
  color      String
  createdAt  DateTime @default(now())

  template Template            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  cards    TemplateCardLabel[]

  @@index([templateId])
}

model TemplateCardLabel {
  cardId  String
  labelId String

  card  TemplateCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label TemplateLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
}

model TemplateChecklist {
  id        String   @id @default(cuid())
  cardId    String
  title     String
  position  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card  TemplateCard            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items TemplateChecklistItem[]

  @@index([cardId, position])
}

model TemplateChecklistItem {
  id          String   @id @default(cuid())
  checklistId String
  text        String
  done        Boolean  @default(false)
  position    Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checklist TemplateChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId, position])
}
